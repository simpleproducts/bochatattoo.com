# Public base URL for image assets served from R2.
# Use the R2 public bucket URL (https://pub-xxxxxxxx.r2.dev) or your custom domain.
NEXT_PUBLIC_IMAGES_BASE_URL=https://images.bochatattoo.com

# Cloudflare R2 credentials — used by scripts/upload-images.mjs, the migration
# script, and the /admin runtime (image upload + manifest writes).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# Brevo (newsletter) — server-only. Generate at https://app.brevo.com/settings/keys/api
# BREVO_LIST_ID is the numeric ID of the list new subscribers go into (optional but recommended).
BREVO_API_KEY=
BREVO_LIST_ID=

# Cloudflare Turnstile (newsletter form anti-abuse) — both keys must be set together,
# or leave both empty to disable. Get them at https://dash.cloudflare.com/?to=/:account/turnstile
# Site key is public (NEXT_PUBLIC_) and ships to the browser; secret key stays server-side.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Admin (image management at /admin)
# ADMIN_PASSWORD          plaintext password to gate /admin
# ADMIN_SESSION_SECRET    HMAC key for the session cookie. Generate with:
#                           openssl rand -hex 32
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# Marketing pixels — both optional. Leave blank to disable each one.
# NEXT_PUBLIC_GA_MEASUREMENT_ID    GA4 measurement id, e.g. "G-XXXXXXXXXX"
# NEXT_PUBLIC_META_PIXEL_ID        Facebook/Meta pixel id, e.g. "1234567890123456"
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_META_PIXEL_ID=
